                    <%= link_to listing_path(1), class: "listing-card relative block" do %>
                        <div class="relative">
                            <img
                                src="https://i0.wp.com/theluxuryeditor.com/wp-content/uploads/2019/02/178793622.jpg?resize=1024%2C683"
                                alt="Room in London"
                                class="w-full h-44 object-cover rounded-lg transition-all duration-300"
                                data-transition-name="listing-1"
                            />
                            <button
                                class="absolute top-2 right-2 bg-white rounded-full p-1.5 opacity-70 hover:opacity-100 transition z-10"
                                onclick="event.stopPropagation(); event.preventDefault();"
                            >
                                <span class="material-symbols-outlined text-sm">favorite</span>
                            </button>
                            <span
                                class="absolute top-2 left-2 bg-white text-xs font-medium py-1 px-2 rounded-md"
                                >Guest favorite</span
                            >
                        </div>
                        <div class="mt-2">
                            <p class="font-medium">Room in London</p>
                            <p class="text-gray-500 text-sm">$145 for 2 nights</p>
                            <div class="flex items-center">
                                <span class="material-symbols-outlined text-xs">star</span>
