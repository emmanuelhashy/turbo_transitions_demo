                        <button class="h-7 w-7 rounded-full border flex items-center justify-center mr-2">
                            <span class="material-symbols-outlined text-sm">chevron_left</span>
                        </button>
                        <button class="h-7 w-7 rounded-full border flex items-center justify-center">
